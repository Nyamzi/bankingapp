generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  parent
  child
  admin
}

enum TransactionType {
  earn
  spend
}

enum TransactionStatus {
  pending
  approved
  rejected
}

enum GoalStatus {
  active
  completed
  cancelled
}

enum ChoreStatus {
  assigned
  completed
}

model User {
  id                   String              @id @default(cuid())
  fullName             String?
  nin                  String?             @unique
  phoneNumber          String?             @unique
  email                String              @unique
  passwordHash         String
  role                 Role
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  parentChildren       ChildProfile[]      @relation("ParentChildren")
  childProfile         ChildProfile?       @relation("ChildUser")
  createdChores        ChoreAssignment[]   @relation("ParentAssignedChores")
  allowanceSchedules   AllowanceSchedule[] @relation("ParentAllowanceSchedules")
  approvedTransactions Transaction[] @relation("ApproverTransactions")
  lessons       Lesson[]
  quizzes       Quiz[]
}

model ChildProfile {
  id                 String              @id @default(cuid())
  nickname           String
  age                Int
  parentId           String
  childUserId        String              @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  parent             User                @relation("ParentChildren", fields: [parentId], references: [id], onDelete: Cascade)
  childUser          User                @relation("ChildUser", fields: [childUserId], references: [id], onDelete: Cascade)
  wallet             Wallet?
  savingsGoals       SavingsGoal[]
  budgets            Budget[]
  achievements       Achievement[]
  transactions       Transaction[]
  chores             ChoreAssignment[]
  allowanceSchedules AllowanceSchedule[]
}

model ChoreAssignment {
  id          String      @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      ChoreStatus @default(assigned)
  completedAt DateTime?
  childId     String
  parentId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  parent      User        @relation("ParentAssignedChores", fields: [parentId], references: [id], onDelete: Cascade)
}

model AllowanceSchedule {
  id          String      @id @default(cuid())
  title       String
  amount      Float
  availableOn DateTime
  notes       String?
  isActive    Boolean     @default(true)
  childId     String
  parentId    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  child       ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  parent      User        @relation("ParentAllowanceSchedules", fields: [parentId], references: [id], onDelete: Cascade)
}

model Wallet {
  id          String         @id @default(cuid())
  childId     String         @unique
  balance     Float          @default(0)
  totalEarned Float          @default(0)
  totalSpent  Float          @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  child       ChildProfile   @relation(fields: [childId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id             String            @id @default(cuid())
  walletId       String
  childId        String
  amount         Float
  type           TransactionType
  status         TransactionStatus @default(pending)
  description    String?
  approvedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  wallet         Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  child          ChildProfile      @relation(fields: [childId], references: [id], onDelete: Cascade)
  approvedBy     User?             @relation("ApproverTransactions", fields: [approvedById], references: [id])
}

model SavingsGoal {
  id             String      @id @default(cuid())
  childId        String
  title          String
  targetAmount   Float
  currentAmount  Float       @default(0)
  status         GoalStatus  @default(active)
  targetDate     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  child          ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model Budget {
  id             String      @id @default(cuid())
  childId        String
  monthlyLimit   Float
  isActive       Boolean     @default(true)
  periodStart    DateTime    @default(now())
  periodEnd      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  child          ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model Achievement {
  id             String      @id @default(cuid())
  childId        String
  title          String
  description    String?
  points         Int         @default(0)
  unlockedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  child          ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model Lesson {
  id             String      @id @default(cuid())
  title          String
  content        String
  isPublished    Boolean     @default(false)
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  createdBy      User        @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model Quiz {
  id             String      @id @default(cuid())
  title          String
  isPublished    Boolean     @default(false)
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  createdBy      User        @relation(fields: [createdById], references: [id], onDelete: Cascade)
}